# syntax=docker/dockerfile:1
FROM python:3.13-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1

# Install uv for fast dependency install
RUN pip install uv

# Copy pyproject.toml first (for dependency caching)
COPY pyproject.toml uv.lock* .env.example* ./

# Install Python dependencies (includes discord.py)
RUN uv sync --no-dev

# Copy application code
COPY src/ ./src/

# Copy entrypoint
COPY bot_entrypoint.sh /app/bot_entrypoint.sh
RUN chmod +x /app/bot_entrypoint.sh

CMD ["/app/bot_entrypoint.sh"]