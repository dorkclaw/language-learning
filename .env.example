# ============================================================
# BBC Noticias Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Hugging Face (required for Speaker Diarization) ---
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# --- DeepSeek (optional — legacy) ---
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# --- OpenRouter (required for BBC Bot) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (default: openrouter/auto = best-value model selected by OpenRouter)
# Examples:
#   openrouter/google/gemini-2.0-flash
#   openrouter/deepseek/deepseek-chat-v3
#   openrouter/anthropic/claude-3-haiku
OPENROUTER_MODEL=openrouter/auto

# --- Discord (optional) ---
# Get your webhook URL from Discord channel settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# --- Telegram (optional) ---
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Get your chat ID via @userinfobot or the getUpdates API
TELEGRAM_CHAT_ID=123456789

# --- Behaviour (optional) ---
# How many hours to look back in the RSS feed (default: 24)
MAX_AGE_HOURS=24
# How many stories to include in the selection prompt (default: 15)
MAX_STORIES_FOR_SELECTION=15
# Set to "true" to run without sending messages (default: false)
DRY_RUN=false
# Hours between bot runs when running in loop mode (default: 24)
SCHEDULE_HOURS=24